# =============================================================================
# Phygitalia · apps/web — Variables de entorno (plantilla)
# =============================================================================
# Copia este archivo a `.env.local` (desarrollo) y define las mismas vars en
# Vercel (Project → Settings → Environment Variables) para producción.
#
# ⚠️ Las variables NEXT_PUBLIC_* se exponen al navegador. Las demás son SÓLO de
#    servidor: nunca las prefijes con NEXT_PUBLIC_ ni las uses en componentes
#    cliente.
# =============================================================================

# --- Supabase (proyecto kfgpxbwuyksrwzxuggif) --------------------------------
# URL del proyecto. Dashboard → Project Settings → Data API → Project URL.
NEXT_PUBLIC_SUPABASE_URL="https://kfgpxbwuyksrwzxuggif.supabase.co"

# Clave anónima (pública, segura para el navegador; la RLS protege los datos).
# Dashboard → Project Settings → API Keys → anon / public.
NEXT_PUBLIC_SUPABASE_ANON_KEY="pega-aqui-tu-anon-key"

# Clave service-role (SECRETA, SÓLO servidor: omite RLS). Se usa para persistir
# la memoria privada de los Oráculos y para moderación del chat público.
# Dashboard → Project Settings → API Keys → service_role.  NUNCA la publiques.
SUPABASE_SERVICE_ROLE_KEY="pega-aqui-tu-service-role-key"

# --- OpenAI (GPT 5.4, Oráculos) ----------------------------------------------
# Clave de la API de OpenAI (SECRETA, sólo servidor). Sin ella, /api/oracle
# responde 503 con un mensaje claro.
OPENAI_API_KEY="sk-pega-aqui-tu-openai-key"

# (Opcional) Sobrescribir el modelo por defecto ("gpt-5.4").
# OPENAI_MODEL="gpt-5.4"
